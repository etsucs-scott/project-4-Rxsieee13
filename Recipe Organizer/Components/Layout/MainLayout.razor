@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-logo">🍳</div>
            <h2>Recipe Organizer</h2>
            <p>Plan. Save. Cook.</p>
        </div>

        <nav class="nav-links">
            <NavLink href="/" Match="NavLinkMatch.All">🏠 Home</NavLink>
            <NavLink href="/recipes">🍽 Recipes</NavLink>
            <NavLink href="/add-recipe">➕ Add Recipe</NavLink>
            <NavLink href="/shopping-list">🛒 Shopping List</NavLink>
            <NavLink href="/stats">📊 Stats</NavLink>
        </nav>

        <button class="theme-button" @onclick="ToggleDarkMode">
            🌙 Dark Mode
        </button>
    </aside>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private bool darkMode = false;

    private async Task ToggleDarkMode()
    {
        darkMode = !darkMode;
        await JS.InvokeVoidAsync("setTheme", darkMode ? "dark-mode" : "");
    }
}
