@page "/stats"

@inject RecipeManager RecipeManager

<h2>📊 Ingredient Stats</h2>

<!-- INGREDIENT STATS -->
<div class="recipe-card">
    @foreach (var s in stats)
    {
        <p>@s.Key — used in @s.Value recipe(s)</p>
    }
</div>

@code {
    private Dictionary<string, int> stats = new();

    protected override void OnInitialized()
    {
        stats = RecipeManager.GetMostUsedIngredients();
    }
}