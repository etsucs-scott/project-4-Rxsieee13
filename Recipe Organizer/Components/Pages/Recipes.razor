@page "/recipes"

@inject RecipeManager RecipeManager
@inject FileService FileService

<h2>🍽 Recipes</h2>

<!-- SEARCH AND FILTER -->
<input @bind="searchText" placeholder="Search recipes..." />

<button @onclick="Search">Search</button>

<label>
    <input type="checkbox" @bind="favoritesOnly" />
    Favorites Only
</label>

<!-- RECIPE DETAILS -->
@if (selectedRecipe != null)
{
    <div class="recipe-detail-card">
        <button class="close-btn" @onclick="CloseDetails">X</button>

        <h2>@selectedRecipe.Name</h2>
        <p><b>Category:</b> @selectedRecipe.Category</p>

        <h3>Ingredients</h3>
        <ul>
            @foreach (var ingredient in selectedRecipe.Ingredients)
            {
                <li>@ingredient.Quantity @ingredient.Unit @ingredient.Name</li>
            }
        </ul>

        <h3>Instructions</h3>
        <p>@selectedRecipe.Instructions</p>
    </div>
}

<!-- RECIPE GRID -->
<div class="recipe-grid">
    @foreach (var r in recipes)
    {
        <div class="recipe-card @(r.IsFavorite ? "favorite" : "")" @onclick="() => ShowDetails(r)">
            <h3>@r.Name</h3>
            <p><b>Category:</b> @r.Category</p>

            <button class="favorite-btn" @onclick:stopPropagation="true" @onclick="() => Toggle(r)">
                @(r.IsFavorite ? "💖 Favorite" : "🤍 Favorite")
            </button>

            <button @onclick:stopPropagation="true" @onclick="() => Delete(r)">
                Delete
            </button>
        </div>
    }
</div>

@code {
    private List<Recipe> recipes = new();
    private string searchText = "";
    private bool favoritesOnly = false;
    private Recipe? selectedRecipe = null;

    protected override void OnInitialized()
    {
        recipes = RecipeManager.GetAll();
    }

    private void Search()
    {
        var result = RecipeManager.SearchByName(searchText);

        if (favoritesOnly)
            result = result.Where(r => r.IsFavorite).ToList();

        recipes = result;
    }

    private void ShowDetails(Recipe recipe)
    {
        selectedRecipe = recipe;
    }

    private void CloseDetails()
    {
        selectedRecipe = null;
    }

    private void Toggle(Recipe r)
    {
        RecipeManager.ToggleFavorite(r);
        FileService.Save(RecipeManager.GetAll());
    }

    private void Delete(Recipe r)
    {
        RecipeManager.DeleteRecipe(r);
        FileService.Save(RecipeManager.GetAll());
        recipes = RecipeManager.GetAll();
        selectedRecipe = null;
    }
}