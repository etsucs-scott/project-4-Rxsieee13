@inject RecipeManager RecipeManager
@inject FileService FileService

<h2>🍽 Recipes</h2>

<div class="section">
    <input @bind="searchText" placeholder="Search recipes..." />
    <button class="btn btn-primary" @onclick="Search">Search</button>

    <label style="margin-left:10px;">
        <input type="checkbox" @bind="favoritesOnly" />
        Favorites Only
    </label>
</div>

<div class="recipe-grid">
@foreach (var r in recipes)
{
    <div class="recipe-card @(r.IsFavorite ? "favorite" : "")">
        <h4>@r.Name</h4>
        <p><b>Category:</b> @r.Category</p>

        <div>
            <button @onclick="()=>Toggle(r)">
                @(r.IsFavorite ? "⭐" : "☆")
            </button>

            <button class="btn btn-danger btn-sm" @onclick="()=>Delete(r)">
                Delete
            </button>
        </div>
    </div>
}
</div>