@page "/"

<section class="hero-card">
    <div>
        <span class="badge"> Recipe Organizer</span>
        <h1>Cook smarter with your personal recipe hub.</h1>
        <p>
            Save recipes, search ingredients, favorite meals, and generate shopping lists all in one clean app.
        </p>

        <div class="hero-actions">
            <a href="/add-recipe" class="primary-link">➕ Add Recipe</a>
            <a href="/recipes" class="secondary-link">🍽 View Recipes</a>
        </div>
    </div>

    <div class="hero-emoji">🥘</div>
</section>

<section class="feature-grid">
    <div class="feature-card">
        <div class="feature-icon">🔎</div>
        <h3>Ingredient Search</h3>
        <p>Find meals based on ingredients you already have.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon">🛒</div>
        <h3>Shopping Lists</h3>
        <p>Combine ingredients from recipes automatically.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon">⭐</div>
        <h3>Favorites</h3>
        <p>Star your favorite recipes for quick access.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3>Stats</h3>
        <p>Track your most-used ingredients over time.</p>
    </div>
</section>
