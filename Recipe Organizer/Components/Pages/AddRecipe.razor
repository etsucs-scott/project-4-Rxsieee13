@page "/add-recipe"

@inject RecipeManager RecipeManager
@inject FileService FileService

<h2>➕ Add Recipe</h2>

<div class="recipe-card">
    <input @bind="recipe.Name" placeholder="Recipe Name" />
    <input @bind="recipe.Category" placeholder="Category" />

    <h4>Ingredients</h4>

    <input @bind="ingredientName" placeholder="Ingredient name" />
    <input @bind="qty" type="number" placeholder="Qty" />
    <input @bind="unit" placeholder="Unit" />

    <button @onclick="AddIngredient">Add Ingredient</button>

    <ul>
        @foreach (var i in recipe.Ingredients)
        {
            <li>@i.Name (@i.Quantity @i.Unit)</li>
        }
    </ul>

    <textarea @bind="recipe.Instructions" placeholder="Instructions"></textarea>

    <button @onclick="Save">Save Recipe</button>
</div>

@code {
    private Recipe recipe = new();
    private string ingredientName = "";
    private double qty;
    private string unit = "";
    private string message = "";

    private void AddIngredient()
    {
        recipe.Ingredients.Add(new Ingredient
        {
            Name = ingredientName,
            Quantity = qty,
            Unit = unit
        });

        ingredientName = "";
        qty = 0;
        unit = "";
    }

    private void Save()
    {
        RecipeManager.AddRecipe(recipe);
        FileService.Save(RecipeManager.GetAll());
        recipe = new Recipe();
        message = "💖 Recipe saved successfully!";
    }
}

@if (!string.IsNullOrWhiteSpace(message)) 
{
    <p class="success-message">@message</p>
}