@page "/shopping-list"

@inject RecipeManager RecipeManager
@inject ShoppingListService ShoppingListService

<h2>🛒 Generate Shopping List</h2>

<div class="form-card">
    <input @bind="recipeName" placeholder="Type recipe name..." />

    <button @onclick="GenerateForRecipe">
        Generate List
    </button>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="success-message">@message</p>
    }
</div>

@if (list.Count > 0)
{
    <div class="recipe-card">
        <h3>Shopping List for @selectedRecipeName</h3>

        @foreach (var item in list)
        {
            <p>💕 @item.Name — @item.Quantity @item.Unit</p>
        }
    </div>
}

@code {
    private string recipeName = "";
    private string selectedRecipeName = "";
    private string message = "";
    private List<Ingredient> list = new();

    private void GenerateForRecipe()
    {
        var recipe = RecipeManager.GetAll()
            .FirstOrDefault(r => r.Name.Contains(recipeName, StringComparison.OrdinalIgnoreCase));

        if (recipe == null)
        {
            list.Clear();
            message = "No recipe found with that name.";
            return;
        }

        selectedRecipeName = recipe.Name;
        list = ShoppingListService.Generate(new List<Recipe> { recipe });
        message = "💖 Shopping list generated!";
    }
}