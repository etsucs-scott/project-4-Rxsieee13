@page "/shopping-list"

@inject RecipeManager RecipeManager
@inject ShoppingListService ShoppingListService

<h2>🛒 Shopping List</h2>

<button @onclick="Generate">Generate List</button>

<div class="recipe-card">
    @foreach (var i in list)
    {
        <p>@i.Name — @i.Quantity @i.Unit</p>
    }
</div>

@code {
    private List<Ingredient> list = new();

    private void Generate()
    {
        list = ShoppingListService.Generate(RecipeManager.GetAll());
    }
}