@inject RecipeManager RecipeManager
@inject ShoppingListService Service

<h2>🛒 Shopping List</h2>

<button class="btn btn-primary" @onclick="Generate">
    Generate List
</button>

<div class="recipe-card">
    @foreach (var i in list)
    {
        <p>@i.Name — @i.Quantity @i.Unit</p>
    }
</div>
